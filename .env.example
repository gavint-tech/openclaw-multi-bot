# ── OpenClaw Gateway ────────────────────────────────────────────────────────
# ใส่ API key ของ provider ที่ agent แต่ละตัวจะอ้างอิงผ่าน team-config.json
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# Gateway network bind (localhost = ปลอดภัยกว่า, lan = เข้าจาก network ได้)
OPENCLAW_GATEWAY_BIND=localhost

# Ports (เปลี่ยนถ้าชน port อื่น)
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790

# Directories (แก้ path ถ้าต้องการ)
OPENCLAW_CONFIG_DIR=~/.openclaw
OPENCLAW_WORKSPACE_DIR=~/openclaw/workspace

# ── Office UI ────────────────────────────────────────────────────────────────
UI_PORT=3000
