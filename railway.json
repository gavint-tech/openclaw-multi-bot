{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "docker/Dockerfile.ui",
    "watchPatterns": [
      "src/**",
      "docker/**",
      ".env.railway.example",
      "README.md",
      "docs/deployment/railway.md",
      "railway.json"
    ]
  },
  "deploy": {
    "healthcheckPath": "/"
  }
}
